{
  "name": "dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "prebuild:staging": "node scripts/verify-env.mjs staging",
    "prebuild:production": "node scripts/verify-env.mjs production",
    "predeploy:staging": "npm run build:staging",
    "predeploy:production": "npm run build:production",
    "deploy:staging": "wrangler pages deploy dist --project-name=botos-platform-staging --branch=main --commit-dirty=false",
    "deploy:production": "wrangler pages deploy dist --project-name=botos-platform --branch=main --commit-dirty=false",
    "postdeploy:staging": "node scripts/verify-deploy.mjs staging",
    "postdeploy:production": "node scripts/verify-deploy.mjs production",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
